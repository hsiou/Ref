{
  "_description": "Reference layout patterns for SlideSpec JSON. Use these as building blocks when designing presentations. All positions for 10\" x 5.625\" canvas (16:9). Replace color values with your chosen theme.",

  "title_slide": {
    "_when": "First slide of every deck. Full dark background, large title, subtitle, metadata rows.",
    "_structure": "Top accent bar → eyebrow label → title → accent underline → subtitle → divider → metadata key-value rows",
    "example": {
      "Background": "003D44",
      "Elements": [
        {"Type": "shape", "X": 0, "Y": 0, "W": 10, "H": 0.06, "Fill": "0891B2", "_comment": "top accent bar"},
        {"Type": "text", "X": 0.7, "Y": 0.4, "W": 5, "H": 0.3, "Text": "EYEBROW LABEL", "FontSize": 11, "Color": "99D5DB", "Bold": true},
        {"Type": "text", "X": 0.7, "Y": 1.0, "W": 8.6, "H": 0.8, "Text": "Presentation Title", "FontSize": 40, "FontName": "Georgia", "Color": "FFFFFF", "Bold": true},
        {"Type": "shape", "X": 0.7, "Y": 1.9, "W": 2.0, "H": 0.04, "Fill": "2DD4BF", "_comment": "accent underline"},
        {"Type": "text", "X": 0.7, "Y": 2.2, "W": 8.6, "H": 0.5, "Text": "Subtitle or tagline", "FontSize": 18, "Color": "E0F7FA"},
        {"Type": "shape", "X": 0.7, "Y": 3.2, "W": 8.6, "H": 0.01, "Fill": "1A6B75", "_comment": "divider"},
        {"Type": "text", "X": 0.7, "Y": 3.4, "W": 1.5, "H": 0.25, "Text": "Label", "FontSize": 10, "Color": "99D5DB", "Bold": true},
        {"Type": "text", "X": 2.4, "Y": 3.4, "W": 5, "H": 0.25, "Text": "Value", "FontSize": 10, "Color": "E0F7FA"}
      ]
    }
  },

  "content_with_cards": {
    "_when": "Content slide with two side-by-side cards. Use for comparisons, dual concepts, before/after.",
    "_structure": "Top accent bar → eyebrow → title → accent underline → body text → two filled cards with accent left bar → bullet list below",
    "example": {
      "Background": "F0FDFA",
      "Elements": [
        {"Type": "shape", "X": 0, "Y": 0, "W": 10, "H": 0.06, "Fill": "0891B2"},
        {"Type": "text", "X": 0.7, "Y": 0.25, "W": 4, "H": 0.25, "Text": "SECTION LABEL", "FontSize": 11, "Color": "0891B2", "Bold": true},
        {"Type": "text", "X": 0.7, "Y": 0.6, "W": 8.6, "H": 0.5, "Text": "Slide Heading", "FontSize": 28, "FontName": "Georgia", "Color": "003D44", "Bold": true},
        {"Type": "shape", "X": 0.7, "Y": 1.15, "W": 1.5, "H": 0.04, "Fill": "2DD4BF"},
        {"Type": "text", "X": 0.7, "Y": 1.4, "W": 8.6, "H": 0.35, "Text": "Brief explanatory sentence for context.", "FontSize": 13, "Color": "1A6B75"},
        {"Type": "shape", "X": 0.7, "Y": 2.0, "W": 4.0, "H": 1.5, "Fill": "005562", "BorderRadius": 6, "_comment": "left card"},
        {"Type": "text", "X": 1.0, "Y": 2.1, "W": 3.4, "H": 0.3, "Text": "Card Title", "FontSize": 13, "Color": "2DD4BF", "Bold": true},
        {"Type": "text", "X": 1.0, "Y": 2.45, "W": 3.4, "H": 0.9, "Text": "Card content goes here.\nUse line breaks for\nmultiple points.", "FontSize": 11, "Color": "E0F7FA"},
        {"Type": "shape", "X": 5.3, "Y": 2.0, "W": 4.0, "H": 1.5, "Fill": "005562", "BorderRadius": 6, "_comment": "right card"},
        {"Type": "text", "X": 5.6, "Y": 2.1, "W": 3.4, "H": 0.3, "Text": "Card Title", "FontSize": 13, "Color": "2DD4BF", "Bold": true},
        {"Type": "text", "X": 5.6, "Y": 2.45, "W": 3.4, "H": 0.9, "Text": "Card content goes here.\nMatching structure to\nthe left card.", "FontSize": 11, "Color": "E0F7FA"}
      ]
    }
  },

  "content_with_bullets": {
    "_when": "Standard content slide with a heading and bullet list. Most common layout.",
    "_structure": "Top accent bar → eyebrow → title → accent underline → bullet list",
    "example": {
      "Background": "F0FDFA",
      "Elements": [
        {"Type": "shape", "X": 0, "Y": 0, "W": 10, "H": 0.06, "Fill": "0891B2"},
        {"Type": "text", "X": 0.7, "Y": 0.25, "W": 4, "H": 0.25, "Text": "SECTION LABEL", "FontSize": 11, "Color": "0891B2", "Bold": true},
        {"Type": "text", "X": 0.7, "Y": 0.6, "W": 8.6, "H": 0.5, "Text": "Slide Heading", "FontSize": 28, "FontName": "Georgia", "Color": "003D44", "Bold": true},
        {"Type": "shape", "X": 0.7, "Y": 1.15, "W": 1.5, "H": 0.04, "Fill": "2DD4BF"},
        {"Type": "list", "X": 0.7, "Y": 1.5, "W": 8.6, "H": 3.0, "ListType": "ul", "Items": [
          {"Text": "First key point — concise and direct", "FontSize": 14, "Color": "003D44"},
          {"Text": "Second key point with supporting detail", "FontSize": 14, "Color": "003D44"},
          {"Text": "Third key point — no more than 6 words ideally", "FontSize": 14, "Color": "003D44"},
          {"Text": "Sub-point with additional context", "FontSize": 12, "Color": "1A6B75", "Level": 1}
        ]}
      ]
    }
  },

  "stat_cards": {
    "_when": "Metrics, numbers, key statistics. Use filled cards with large numbers.",
    "_structure": "Top accent bar → eyebrow → title → 3 stat cards (shape background + number + label)",
    "example": {
      "Background": "F0FDFA",
      "Elements": [
        {"Type": "shape", "X": 0, "Y": 0, "W": 10, "H": 0.06, "Fill": "0891B2"},
        {"Type": "text", "X": 0.7, "Y": 0.25, "W": 4, "H": 0.25, "Text": "KEY METRICS", "FontSize": 11, "Color": "0891B2", "Bold": true},
        {"Type": "text", "X": 0.7, "Y": 0.6, "W": 8.6, "H": 0.5, "Text": "Vaccine Efficacy Data", "FontSize": 28, "FontName": "Georgia", "Color": "003D44", "Bold": true},
        {"Type": "shape", "X": 0.7, "Y": 1.15, "W": 1.5, "H": 0.04, "Fill": "2DD4BF"},

        {"Type": "shape", "X": 0.7, "Y": 1.6, "W": 2.7, "H": 1.4, "Fill": "005562", "BorderRadius": 6},
        {"Type": "text", "X": 0.9, "Y": 1.7, "W": 2.3, "H": 0.6, "Text": "97%", "FontSize": 36, "Color": "2DD4BF", "Bold": true},
        {"Type": "text", "X": 0.9, "Y": 2.3, "W": 2.3, "H": 0.4, "Text": "Seroconversion\nafter 2 doses", "FontSize": 10, "Color": "99D5DB"},

        {"Type": "shape", "X": 3.65, "Y": 1.6, "W": 2.7, "H": 1.4, "Fill": "005562", "BorderRadius": 6},
        {"Type": "text", "X": 3.85, "Y": 1.7, "W": 2.3, "H": 0.6, "Text": "12-18", "FontSize": 36, "Color": "2DD4BF", "Bold": true},
        {"Type": "text", "X": 3.85, "Y": 2.3, "W": 2.3, "H": 0.4, "Text": "Basic reproduction\nnumber (R\u2080)", "FontSize": 10, "Color": "99D5DB"},

        {"Type": "shape", "X": 6.6, "Y": 1.6, "W": 2.7, "H": 1.4, "Fill": "005562", "BorderRadius": 6},
        {"Type": "text", "X": 6.8, "Y": 1.7, "W": 2.3, "H": 0.6, "Text": "95%", "FontSize": 36, "Color": "2DD4BF", "Bold": true},
        {"Type": "text", "X": 6.8, "Y": 2.3, "W": 2.3, "H": 0.4, "Text": "Herd immunity\nthreshold", "FontSize": 10, "Color": "99D5DB"}
      ]
    }
  },

  "closing_slide": {
    "_when": "Last slide of every deck. Full dark background, summary bullets, contact/attribution.",
    "_structure": "Top accent bar (different color) → eyebrow → title → accent underline → bullet list → divider → footer",
    "example": {
      "Background": "003D44",
      "Elements": [
        {"Type": "shape", "X": 0, "Y": 0, "W": 10, "H": 0.06, "Fill": "2DD4BF"},
        {"Type": "text", "X": 0.7, "Y": 0.25, "W": 4, "H": 0.25, "Text": "KEY TAKEAWAYS", "FontSize": 11, "Color": "99D5DB", "Bold": true},
        {"Type": "text", "X": 0.7, "Y": 0.6, "W": 8.6, "H": 0.5, "Text": "Summary & Next Steps", "FontSize": 32, "FontName": "Georgia", "Color": "FFFFFF", "Bold": true},
        {"Type": "shape", "X": 0.7, "Y": 1.15, "W": 1.5, "H": 0.04, "Fill": "2DD4BF"},
        {"Type": "list", "X": 0.7, "Y": 1.5, "W": 8.6, "H": 2.5, "ListType": "ul", "Items": [
          {"Text": "First takeaway — most important point", "FontSize": 14, "Color": "FFFFFF"},
          {"Text": "Second takeaway — actionable next step", "FontSize": 14, "Color": "FFFFFF"},
          {"Text": "Third takeaway — call to action", "FontSize": 14, "Color": "FFFFFF"}
        ]},
        {"Type": "shape", "X": 0.7, "Y": 4.3, "W": 8.6, "H": 0.01, "Fill": "1A6B75"},
        {"Type": "text", "X": 0.7, "Y": 4.5, "W": 8.6, "H": 0.25, "Text": "Organization Name  |  Department", "FontSize": 10, "Color": "99D5DB"}
      ]
    }
  },

  "content_with_image_left": {
    "_when": "Content slide with an image on the left and text/bullets on the right. Most common image layout.",
    "_structure": "Top accent bar → eyebrow → title → accent underline → image (left half) → text/bullets (right half)",
    "_rules": "Image MUST NOT exceed 4.0\" wide or 3.0\" tall. Always leave the right half for text. Never full-bleed images.",
    "example": {
      "Background": "F0FDFA",
      "Elements": [
        {"Type": "shape", "X": 0, "Y": 0, "W": 10, "H": 0.06, "Fill": "0891B2"},
        {"Type": "text", "X": 0.7, "Y": 0.25, "W": 4, "H": 0.25, "Text": "SECTION LABEL", "FontSize": 11, "Color": "0891B2", "Bold": true},
        {"Type": "text", "X": 0.7, "Y": 0.6, "W": 8.6, "H": 0.5, "Text": "Slide Heading", "FontSize": 28, "FontName": "Georgia", "Color": "003D44", "Bold": true},
        {"Type": "shape", "X": 0.7, "Y": 1.15, "W": 1.5, "H": 0.04, "Fill": "2DD4BF"},
        {"Type": "shape", "X": 0.5, "Y": 1.4, "W": 4.2, "H": 3.2, "Fill": "FFFFFF", "BorderColor": "99D5DB", "BorderWidth": 0.5, "BorderRadius": 4, "_comment": "image frame"},
        {"Type": "image", "X": 0.6, "Y": 1.5, "W": 4.0, "H": 3.0, "Src": "/tmp/deck-images/photo.png"},
        {"Type": "text", "X": 5.2, "Y": 1.4, "W": 4.1, "H": 0.3, "Text": "Key Findings", "FontSize": 14, "Color": "0891B2", "Bold": true},
        {"Type": "list", "X": 5.2, "Y": 1.8, "W": 4.1, "H": 2.5, "ListType": "ul", "Items": [
          {"Text": "First point about the image", "FontSize": 13, "Color": "003D44"},
          {"Text": "Second point with clinical detail", "FontSize": 13, "Color": "003D44"},
          {"Text": "Third point — keep concise", "FontSize": 13, "Color": "003D44"}
        ]},
        {"Type": "text", "X": 5.2, "Y": 4.5, "W": 4.1, "H": 0.25, "Text": "Source: Wikimedia Commons, CC BY-SA", "FontSize": 9, "Color": "99D5DB"}
      ]
    }
  },

  "content_with_image_right": {
    "_when": "Content slide with text/bullets on the left and an image on the right. Use for visual evidence.",
    "_structure": "Top accent bar → eyebrow → title → accent underline → text/bullets (left half) → image (right half)",
    "_rules": "Image MUST NOT exceed 4.0\" wide or 3.0\" tall. Always leave the left half for text. Never full-bleed images.",
    "example": {
      "Background": "F0FDFA",
      "Elements": [
        {"Type": "shape", "X": 0, "Y": 0, "W": 10, "H": 0.06, "Fill": "0891B2"},
        {"Type": "text", "X": 0.7, "Y": 0.25, "W": 4, "H": 0.25, "Text": "CLINICAL IMAGING", "FontSize": 11, "Color": "0891B2", "Bold": true},
        {"Type": "text", "X": 0.7, "Y": 0.6, "W": 8.6, "H": 0.5, "Text": "Slide Heading", "FontSize": 28, "FontName": "Georgia", "Color": "003D44", "Bold": true},
        {"Type": "shape", "X": 0.7, "Y": 1.15, "W": 1.5, "H": 0.04, "Fill": "2DD4BF"},
        {"Type": "list", "X": 0.7, "Y": 1.4, "W": 4.1, "H": 2.5, "ListType": "ul", "Items": [
          {"Text": "Clinical context for the image", "FontSize": 13, "Color": "003D44"},
          {"Text": "Key finding or observation", "FontSize": 13, "Color": "003D44"},
          {"Text": "Clinical significance", "FontSize": 13, "Color": "003D44"}
        ]},
        {"Type": "shape", "X": 5.3, "Y": 1.4, "W": 4.2, "H": 3.2, "Fill": "FFFFFF", "BorderColor": "99D5DB", "BorderWidth": 0.5, "BorderRadius": 4, "_comment": "image frame"},
        {"Type": "image", "X": 5.4, "Y": 1.5, "W": 4.0, "H": 3.0, "Src": "/tmp/deck-images/clinical.jpg"},
        {"Type": "text", "X": 5.3, "Y": 4.7, "W": 4.2, "H": 0.25, "Text": "Source: CDC PHIL, public domain", "FontSize": 9, "Color": "99D5DB"}
      ]
    }
  },

  "design_rules": {
    "images": "NEVER full-bleed. Max 4.0\" wide, 3.0\" tall. Always paired with text on the opposite half. Wrap in a bordered shape frame (0.1\" padding). Attribution in 9pt below the frame.",
    "canvas": "10\" x 5.625\" (16:9)",
    "margins": "All text >12pt must be >0.5\" from edges, especially bottom (Y + H < 5.125)",
    "title_area": "Top 15-20% of slide (Y: 0.25-1.2)",
    "content_area": "Y: 1.2 - 4.5 (stay above 5.125 bottom boundary)",
    "accent_bar": "Full-width shape at Y:0, H:0.06 in primary or accent color",
    "accent_underline": "W:1.5-2.0, H:0.04 below the title in accent color",
    "divider": "Full-width shape H:0.01 in divider color to separate sections",
    "cards": "Filled shapes (surface color) with BorderRadius:6, text inside with 0.3\" padding",
    "fonts": "Title: theme title font 28-40pt bold. Body: theme body font 13-16pt. Labels: 10-11pt.",
    "alternating_backgrounds": "Title/closing slides use background color (dark). Content slides use light (#F0FDFA or similar)."
  }
}
